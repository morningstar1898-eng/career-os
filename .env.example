# Career OS — environment template
# Copy to .env and fill in real values. NEVER commit .env or real secrets.

# ── Branding ──────────────────────────────────────────────
APP_NAME=CareerOS                  # internal name (repo/infra compatibility)
PUBLIC_APP_NAME=Career OS          # user-facing display name (change when the SaaS brand is chosen)

# ── Backend security (REQUIRED in production) ─────────────
CAREER_OS_API_TOKEN=generate-a-long-random-token          # bearer token for legacy private API routes
CAREER_OS_PASSWORD=choose-a-strong-dashboard-password     # legacy dashboard login password
INGEST_SECRET=generate-another-random-secret              # secret for workflow → API ingest calls
AUTH_SECRET=generate-a-long-random-jwt-signing-secret     # signs multi-user session tokens (SaaS /v1 routes)
ADMIN_EMAIL=                       # signups with this email get the admin role

# ── SaaS trial & billing ──────────────────────────────────
TRIAL_DAYS=3                       # free trial length (no credit card required)
STRIPE_SECRET_KEY=                 # sk_... (leave empty until billing is set up)
STRIPE_WEBHOOK_SECRET=             # whsec_... (webhooks are the source of truth for plans)
STRIPE_PRICE_STARTER=              # price_... IDs mapping Stripe prices → internal plans
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# ── Gmail integration (Pro+ plans; scaffold) ──────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=                # e.g. https://yourapp.com/gmail/callback

# ── Admin kill switches (cost/abuse protection) ───────────
DISABLE_AI_RUNS=false
DISABLE_GMAIL_SYNC=false
DISABLE_APPLICATION_ASSIST=false
DISABLE_NEW_SIGNUPS=false

# ── Runtime flags ─────────────────────────────────────────
ENV=development                    # "production" disables demo seeding routes
PUBLIC_DEMO_MODE=false             # true = serve ONLY a sanitized demo database
ALLOW_MANUAL_RUNS=false            # true = enable POST /runs/trigger (spends API budget)
ALLOWED_ORIGINS=http://localhost:3000   # comma-separated CORS origins

# ── Persistence ───────────────────────────────────────────
CAREER_OS_DB=career_os.db          # SQLite path; production: /home/career-os/career_os.db (persistent mount)
# CAREER_OS_DEMO_DB=career_os_demo.db
# DATABASE_URL=                    # Postgres for real SaaS production — see docs/SAAS_MIGRATION.md

# ── AI keys ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
SERPER_API_KEY=your_serper_key_here          # serper.dev — free 2500 searches/mo

# ── Notion ────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# ── Google (Sheets) ───────────────────────────────────────
GOOGLE_CREDENTIALS_JSON=config/google_credentials.json
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_URL=                  # optional: tracker link shown in the briefing email footer

# ── Email (SMTP for daily briefing) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your_app_password
GMAIL_SENDER=you@example.com

# ── Azure ─────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_STORAGE_CONTAINER=portfolio-charts

# ── Optional integrations ─────────────────────────────────
ELEVENLABS_API_KEY=                # text-to-speech (optional)
ELEVENLABS_VOICE_ID=
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Profile (personalizes the agents; no private resume text here) ──
YOUR_NAME=Your Name
TARGET_ROLES=Data Analyst,Business Intelligence Analyst,Analytics Engineer
TARGET_CITIES=Remote
TARGET_COMPANIES=
DEGREE=Your Degree
SKILLS_CURRENT=SQL,Python,Excel
RESUME_PATH=config/resume.txt      # local, git-ignored file with your resume text
JOBS_PER_DAY=10
FULL_APPLICATIONS=5

# ── Frontend (set in Vercel) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEMO_MODE=false
