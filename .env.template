# ── AI Keys ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
SERPER_API_KEY=your_serper_key_here          # serper.dev — free 2500 searches/mo

# ── Notion ────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id   # the page ID of your briefing DB

# ── Google (Sheets + Gmail) ───────────────────────────────
GOOGLE_CREDENTIALS_JSON=path/to/credentials.json   # downloaded from Google Cloud Console
GOOGLE_SHEET_ID=your_google_sheet_id               # job tracker spreadsheet ID
GMAIL_SENDER=yourjobsearch@gmail.com

# ── Azure ─────────────────────────────────────────────────
AZURE_SQL_CONNECTION_STRING=Driver={ODBC Driver 18 for SQL Server};Server=tcp:yourserver.database.windows.net,1433;Database=yourdb;Uid=yourusername;Pwd=yourpassword;
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=portfolio-charts

# ── Kaggle ────────────────────────────────────────────────
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── Power BI (optional — adds portfolio dashboard) ────────
POWERBI_CLIENT_ID=your_azure_app_client_id
POWERBI_CLIENT_SECRET=your_azure_app_secret
POWERBI_TENANT_ID=your_azure_tenant_id
POWERBI_WORKSPACE_ID=your_powerbi_workspace_id
POWERBI_DATASET_ID=your_powerbi_dataset_id

# ── Your Profile (personalizes every agent) ───────────────
YOUR_NAME=Your Name
TARGET_ROLES=Data Analyst,Business Intelligence Analyst,Analytics Engineer
TARGET_CITIES=Remote,Oklahoma City OK,Dallas TX
RESUME_PATH=config/resume.txt
YEARS_EXPERIENCE=0
DEGREE=MBA in Data Analytics
SKILLS_CURRENT=Excel,Basic SQL,PowerPoint
